.welcome {
  text-align: center;
  font-family: 'Gill Sans', 'Gill Sans MT', Calibri, 'Trebuchet MS', sans-serif;

  background-image: url( images/Illustration.jpg);
  background-repeat: no-repeat;
  background-position: center top; /* push image to the top */

  /* Make the container very tall */
  height: 170px;   /* increase this for more vertical space */

  /* Stretch the image to fill the tall box */
  background-size: 100%;

  /* Font color */
  color: black;

  /* Optional: add padding if you want text lower */
  padding-top: 70px;
}

/* Navbar container */
.navbar {
  text-align: center;
  padding: 0;
  background: #001F3F;
}

/* Navbar links */
.navbar a {
  text-decoration: none;              /* or underline double if you prefer */
  font-family: cursive;
  color: #39CCCC;
  padding: 15px;
  border-radius: 10px;
  transition: all 0.3s ease;          /* smooth animation */
  display: inline-block;              /* allows width animation */
}

/* Hover effect */
.navbar a:hover {
  background-color: rgb(35, 246, 151);
  border-radius: 0px;
}

/* Active (clicked) effect */
.navbar a:active,
.navbar a:focus,
.navbar a.active {
  display: block;              /* make it stretch full width */
  width: 100%;                 /* expand to navbar width */
  border: 2px solid #39CCCC;   /* border highlight */
  border-radius: 0;            /* optional: remove rounded corners */
  background-color: rgb(35, 246, 151);
  color: #001F3F;              /* invert text color for contrast */
}
